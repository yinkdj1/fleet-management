# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fleet_management

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI Chat (Claude Anthropic)
# Sign up at: https://console.anthropic.com/
# Get your API key from the dashboard
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Frontend Base URL (for CORS and redirects)
FRONTEND_BASE_URL=http://localhost:3000

# Twilio SMS Configuration (optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
SUPPORT_PHONE=+1234567890

# Twilio Webhooks (optional)
RESERVATION_SMS_WEBHOOK_URL=https://your-domain.com/api/webhooks/reservation-sms
PRECHECKOUT_SMS_WEBHOOK_URL=https://your-domain.com/api/webhooks/precheckout-sms

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Pre-checkout Auto Scheduler (optional)
PRECHECKOUT_AUTO_ENABLED=true
PRECHECKOUT_AUTO_INTERVAL_MINUTES=15
